{
  "name": "vscode-aem-tools",
  "displayName": "AEM Tools",
  "description": "Developer tooling for Adobe Experience Manager (AEM) supporting HTL/Sightly, OSGi configurations, ClientLibs, and FileVault JCR XML configurations.",
  "version": "1.1.0",
  "publisher": "akio333",
  "license": "GPL-3.0-only",
  "icon": "icon.png",
  "repository": {
    "url": "https://github.com/akio333/vscode-aem-tools"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:xml",
    "onLanguage:aem-clientlib-txt",
    "workspaceContains:jcr_root"
  ],
  "main": "./out/client/src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "htl",
        "aliases": [
          "HTL",
          "Sightly"
        ],
        "extensions": [
          ".htl"
        ]
      },
      {
        "id": "aem-clientlib-txt",
        "aliases": [
          "AEM Client Library Asset List"
        ],
        "filenames": [
          "js.txt",
          "css.txt"
        ]
      }
    ],
    "grammars": [
      {
        "language": "htl",
        "scopeName": "text.html.htl",
        "path": "./syntaxes/htl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "aem-tools.syncToAEM",
        "title": "AEM: Sync to Server",
        "category": "AEM"
      },
      {
        "command": "aem-tools.syncFromAEM",
        "title": "AEM: Sync from Server",
        "category": "AEM"
      },
      {
        "command": "aem-tools.testConnection",
        "title": "AEM: Test Connection",
        "category": "AEM"
      },
      {
        "command": "aem-tools.toggleFeDevMode",
        "title": "AEM: Toggle FE Dev Mode",
        "category": "AEM"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "aem-tools.syncToAEM",
          "group": "aem-tools@1"
        },
        {
          "command": "aem-tools.syncFromAEM",
          "group": "aem-tools@2"
        }
      ],
      "editor/context": [
        {
          "command": "aem-tools.syncToAEM",
          "group": "aem-tools@1"
        },
        {
          "command": "aem-tools.syncFromAEM",
          "group": "aem-tools@2"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "AEM Tools Configuration",
      "properties": {
        "aemTools.host": {
          "type": "string",
          "default": "http://localhost:4502",
          "description": "The URL of the target AEM instance."
        },
        "aemTools.username": {
          "type": "string",
          "default": "admin",
          "description": "AEM Username."
        },
        "aemTools.password": {
          "type": "string",
          "default": "admin",
          "description": "AEM Password."
        },
        "aemTools.feDevMode": {
          "type": "boolean",
          "default": false,
          "description": "Automatically sync changed files under ui.apps/**/jcr_root to AEM."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --minify",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/htmlparser2": "^3.10.7",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@adobe/htlengine": "^6.4.39",
    "aemsync": "^5.2.3",
    "htmlparser2": "^12.0.0",
    "vscode-languageclient": "^8.1.0",
    "vscode-languageserver": "^8.1.0",
    "vscode-languageserver-textdocument": "^1.0.8"
  }
}
